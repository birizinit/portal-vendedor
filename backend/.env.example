# --- Ploomes (CRM) ---
PLOOMES_API_KEY=coloque_sua_chave_aqui
PLOOMES_BASE_URL=https://api2.ploomes.com
PLOOMES_RATE_LIMIT=120
PLOOMES_CACHE_TTL=300

# --- Banco (espelho local) ---
# dev: sqlite | produção (nuvem): postgresql+psycopg://user:pass@host/db
DATABASE_URL=sqlite:///./data/portal.db

# --- App ---
SECRET_KEY=troque-esta-chave-em-producao
PORTAL_ADMIN_EMAIL=gabriel.hernandes@larplasticos.com.br
PORTAL_ADMIN_PASSWORD=admin

# --- Sync da carteira ---
PORTFOLIO_SYNC_PAGE_SIZE=100
PORTFOLIO_SYNC_MAX_PAGES=120
PORTFOLIO_AUTO_SYNC_HOURS=6

# --- Regras de inteligência (alertas) ---
REACTIVATION_FACTOR=1.3
STALE_DEAL_DAYS=7
